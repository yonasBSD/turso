    CREATE TRIGGER trig_temp_main_alias AFTER INSERT ON temp.temp_driver_main_alias BEGIN
        INSERT INTO log_temp_main_alias
        SELECT t.b
        FROM src_temp_main_alias AS t
        WHERE EXISTS (
            SELECT 1
            FROM src_temp_main_alias AS u
            WHERE u.a = new.x AND u.b = t.b
        );
    END;
