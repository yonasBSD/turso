# CASE expression referencing dropped column
@cross-check-integrity
test fail-drop-column-case-expr-ref {
    CREATE TABLE t (a, b, c);
    CREATE TRIGGER tr AFTER INSERT ON t BEGIN UPDATE t SET c = CASE WHEN b > 0 THEN 1 ELSE 0 END; END;
    ALTER TABLE t DROP COLUMN b;
}
