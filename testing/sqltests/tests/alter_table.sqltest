    ALTER TABLE t DROP COLUMN b;
}
expect error {
    error in trigger tr after drop column: no such column:
}

# COALESCE referencing dropped column
@cross-check-integrity
test fail-drop-column-coalesce-ref {
    CREATE TABLE t (a, b, c);
    CREATE TRIGGER tr AFTER INSERT ON t BEGIN UPDATE t SET c = coalesce(b, 0); END;
    ALTER TABLE t DROP COLUMN b;
}
expect error {
    error in trigger tr after drop column: no such column:
}

# IN expression referencing dropped column
@cross-check-integrity
test fail-drop-column-in-expr-ref {
    CREATE TABLE t (a, b, c);
    CREATE TRIGGER tr AFTER INSERT ON t BEGIN UPDATE t SET c = 1 WHERE a IN (b, c); END;
    ALTER TABLE t DROP COLUMN b;
}
expect error {
    error in trigger tr after drop column: no such column:
}

# BETWEEN referencing dropped column
@cross-check-integrity
test fail-drop-column-between-ref {
    CREATE TABLE t (a, b, c);
    CREATE TRIGGER tr AFTER INSERT ON t BEGIN UPDATE t SET c = 1 WHERE a BETWEEN b AND c; END;
    ALTER TABLE t DROP COLUMN b;
}
expect error {
    error in trigger tr after drop column: no such column:
}

# Compound expression (||) referencing dropped column
@cross-check-integrity
test fail-drop-column-compound-expr-ref {
    CREATE TABLE t (a, b, c);
    CREATE TRIGGER tr AFTER INSERT ON t BEGIN UPDATE t SET c = a || b; END;
    ALTER TABLE t DROP COLUMN b;
