@cross-check-integrity
test alter-table-add-column-default-affinity-real {
    CREATE TABLE t(a INTEGER PRIMARY KEY);
    INSERT INTO t VALUES(1);
    ALTER TABLE t ADD COLUMN c REAL DEFAULT '3';
    SELECT a, typeof(c), c FROM t;
}
