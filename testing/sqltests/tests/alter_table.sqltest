@database :memory:

@cross-check-integrity
test alter-table-rename-table {
    CREATE TABLE t1 (x INTEGER PRIMARY KEY, u);
    ALTER TABLE t1 RENAME TO t2;
    SELECT name FROM sqlite_schema WHERE type = 'table';
}
expect {
    t2
}

@cross-check-integrity
test alter-table-rename-autoindex-updated {
    CREATE TABLE new_cas (id integer, database_id integer UNIQUE, cluster_id integer UNIQUE, PRIMARY KEY (id));
    ALTER TABLE new_cas RENAME TO cas;
    SELECT name FROM sqlite_schema WHERE type = 'index' ORDER BY name;
}
expect {
    sqlite_autoindex_cas_1
    sqlite_autoindex_cas_2
}

@cross-check-integrity
test alter-table-rename-then-recreate-with-autoindex {
    CREATE TABLE new_t (a integer, b integer UNIQUE, PRIMARY KEY (a));
    ALTER TABLE new_t RENAME TO t;
    CREATE TABLE IF NOT EXISTS new_t (a integer, b integer UNIQUE, PRIMARY KEY (a));
    SELECT name, tbl_name FROM sqlite_schema WHERE type = 'index' ORDER BY name;
}
expect {
    sqlite_autoindex_new_t_1|new_t
    sqlite_autoindex_t_1|t
}

@cross-check-integrity
test alter-table-rename-column {
    CREATE TABLE t (a INTEGER);
    CREATE INDEX i ON t (a);
    ALTER TABLE t RENAME a TO b;
    SELECT sql FROM sqlite_schema;
}
expect {
    CREATE TABLE t (b INTEGER)
    CREATE INDEX i ON t (b)
}

@skip-if mvcc "views not supported in MVCC mode"
test alter-table-rename-column-view {
    CREATE TABLE t (a, b);
    CREATE VIEW v AS SELECT a, b FROM t;
    ALTER TABLE t RENAME COLUMN b TO c;
    SELECT sql FROM sqlite_schema WHERE type = 'view' AND name = 'v';
}
expect {
    CREATE VIEW v AS SELECT a, c FROM t
}

@skip-if mvcc "views not supported in MVCC mode"
test alter-table-rename-column-view-qualified {
    CREATE TABLE t (a, b);
    CREATE VIEW v AS SELECT t.a, t.b FROM t;
    ALTER TABLE t RENAME COLUMN b TO c;
    SELECT sql FROM sqlite_schema WHERE type = 'view' AND name = 'v';
}
expect {
    CREATE VIEW v AS SELECT t.a, t.c FROM t
}

@skip-if mvcc "views not supported in MVCC mode"
test alter-table-rename-column-view-star {
    CREATE TABLE t (a INT, b TEXT);
    CREATE VIEW v AS SELECT * FROM t;
    ALTER TABLE t RENAME COLUMN b TO c;
    PRAGMA table_info(v);
}
expect {
    0|a|INT|0||0
    1|c|TEXT|0||0
}

# SQLite does not rewrite dependent views (view-on-view) on RENAME COLUMN.
@skip-if mvcc "views not supported in MVCC mode"
@skip-if sqlite "sqlite does not rewrite dependent views on RENAME COLUMN"
test alter-table-rename-column-view-on-view {
    CREATE TABLE t (a, b);
    CREATE VIEW v1 AS SELECT a, b FROM t;
    CREATE VIEW v2 AS SELECT b FROM v1;
    ALTER TABLE t RENAME COLUMN b TO c;
    SELECT sql FROM sqlite_schema WHERE type = 'view' AND name = 'v1';
    SELECT sql FROM sqlite_schema WHERE type = 'view' AND name = 'v2';
}
expect {
    CREATE VIEW v1 AS SELECT a, c FROM t
    CREATE VIEW v2 AS SELECT c FROM v1
}

@skip-if mvcc "views not supported in MVCC mode"
test alter-table-rename-column-view-subquery {
    CREATE TABLE t (a, b);
    CREATE VIEW v AS SELECT a FROM t WHERE EXISTS (SELECT 1 FROM t WHERE t.b = 1);
    ALTER TABLE t RENAME COLUMN b TO c;
    SELECT sql FROM sqlite_schema WHERE type = 'view' AND name = 'v';
}
expect {
    CREATE VIEW v AS SELECT a FROM t WHERE EXISTS (SELECT 1 FROM t WHERE t.c = 1)
}

@skip-if mvcc "views not supported in MVCC mode"
test alter-table-rename-column-view-correlated-subquery {
    CREATE TABLE t (a, b);
    CREATE VIEW v AS SELECT a FROM t WHERE EXISTS (SELECT 1 WHERE t.b = 1);
    ALTER TABLE t RENAME COLUMN b TO c;
    SELECT sql FROM sqlite_schema WHERE type = 'view' AND name = 'v';
}
expect {
    CREATE VIEW v AS SELECT a FROM t WHERE EXISTS (SELECT 1 WHERE t.c = 1)
}

@skip-if mvcc "views not supported in MVCC mode"
test alter-table-rename-column-view-correlated-outer-shadow {
    CREATE TABLE t (a, b);
    CREATE TABLE u (b);
    CREATE VIEW v AS SELECT u.b FROM u WHERE EXISTS (SELECT 1 FROM t WHERE b = 1);
    ALTER TABLE t RENAME COLUMN b TO c;
    SELECT sql FROM sqlite_schema WHERE type = 'view' AND name = 'v';
}
expect {
    CREATE VIEW v AS SELECT u.b FROM u WHERE EXISTS (SELECT 1 FROM t WHERE c = 1)
}

@skip-if mvcc "views not supported in MVCC mode"
test alter-table-rename-column-view-correlated-outer-shadow-nested {
    CREATE TABLE t (a, b);
    CREATE TABLE u (b);
    CREATE VIEW v AS SELECT u.b FROM u WHERE EXISTS (SELECT 1 FROM t WHERE EXISTS (SELECT 1 WHERE b = 1));
    ALTER TABLE t RENAME COLUMN b TO c;
    SELECT sql FROM sqlite_schema WHERE type = 'view' AND name = 'v';
}
expect {
    CREATE VIEW v AS SELECT u.b FROM u WHERE EXISTS (SELECT 1 FROM t WHERE EXISTS (SELECT 1 WHERE c = 1))
}

@skip-if mvcc "views not supported in MVCC mode"
test alter-table-rename-column-view-select-branch {
    CREATE TABLE t (a, b);
    INSERT INTO t VALUES (1, 2);
    CREATE VIEW v AS SELECT s.x FROM (SELECT b AS x FROM t) AS s;
    ALTER TABLE t RENAME COLUMN b TO c;
    SELECT * FROM v;
}
expect {
    2
}

@skip-if mvcc "views not supported in MVCC mode"
test alter-table-rename-column-view-tablecall-branch {
    CREATE TABLE t (a, b);
    INSERT INTO t VALUES (1, 't');
    CREATE VIEW v AS SELECT j.value FROM t JOIN json_each(json_array(t.b)) AS j;
    ALTER TABLE t RENAME COLUMN b TO c;
    SELECT COUNT(*) FROM v;
}
expect {
    1
}

@skip-if mvcc "views not supported in MVCC mode"
test alter-table-rename-column-view-self-cycle {
    CREATE TABLE t (a, b);
    CREATE VIEW v AS SELECT * FROM v;
    ALTER TABLE t RENAME COLUMN b TO c;
}
expect error {
}

@skip-if mvcc "views not supported in MVCC mode"
test alter-table-rename-column-view-mutual-cycle {
    CREATE TABLE t (a, b);
    CREATE VIEW v1 AS SELECT * FROM t;
    CREATE VIEW v2 AS SELECT * FROM v1;
    DROP VIEW v1;
    CREATE VIEW v1 AS SELECT * FROM v2;
    ALTER TABLE t RENAME COLUMN b TO c;
}
expect error {
}

test alter-table-rename-column-view-attached-db-qualified {
    ATTACH ':memory:' AS aux;
    CREATE TABLE t (a, b);
    CREATE TABLE aux.t (a, b);
    CREATE VIEW v AS SELECT a, b FROM aux.t;
}
expect error {
    cannot reference
}

test alter-table-rename-column-trigger-attached-db-same-db {
    ATTACH ':memory:' AS aux;
    CREATE TABLE aux.t (a, b);
    CREATE TABLE aux.log (v);
    CREATE TRIGGER aux.trig AFTER INSERT ON t BEGIN
        INSERT INTO log VALUES (NEW.b);
    END;
    ALTER TABLE aux.t RENAME COLUMN b TO c;
    INSERT INTO aux.t VALUES (1, 7);
    SELECT * FROM aux.log;
}
expect {
    7
}

test alter-table-rename-column-view-attached-db-same-db {
    ATTACH ':memory:' AS aux;
    CREATE TABLE aux.t (a, b);
    CREATE VIEW aux.v AS SELECT b FROM t;
    ALTER TABLE aux.t RENAME COLUMN b TO c;
    SELECT sql FROM aux.sqlite_schema WHERE type = 'view' AND name = 'v';
}
expect {
    CREATE VIEW v AS SELECT c FROM t
}

