# https://github.com/tursodatabase/turso/issues/5632
@cross-check-integrity
test alter_table_add_column_with_single_quote_in_name {
    CREATE TABLE t1(a);
    CREATE TABLE t2(b);
    CREATE TABLE t3(c);
    CREATE INDEX i1 ON t1(a);
    CREATE INDEX i2 ON t2(b);

    CREATE TABLE "z' OR 1=1 -- "(x);
    ALTER TABLE "z' OR 1=1 -- " ADD COLUMN y;

    SELECT lower(rtrim(name)) FROM sqlite_schema WHERE type = 'table' ORDER BY lower(name);
    SELECT replace(replace(lower(sql), '"', ''), ' ', '')
    FROM sqlite_schema
    WHERE type = 'table' AND lower(name) LIKE 'z'' or 1=1 -- %';
    PRAGMA integrity_check;
}
expect {
    t1
    t2
    t3
    z' or 1=1 --
    createtablez'or1=1--(x,y)
    ok
}

# https://github.com/tursodatabase/turso/issues/5632
@cross-check-integrity
test alter_table_drop_column_with_single_quote_in_name {
    CREATE TABLE "z' OR 1=1 -- "(x, y);
    CREATE TABLE ok(v);
    INSERT INTO ok VALUES(1);

    ALTER TABLE "z' OR 1=1 -- " DROP COLUMN y;

    SELECT * FROM ok;
    SELECT replace(replace(lower(sql), '"', ''), ' ', '')
    FROM sqlite_schema
    WHERE type = 'table' AND lower(name) LIKE 'z'' or 1=1 -- %';
    PRAGMA integrity_check;
}
expect {
    1
    createtablez'or1=1--(x)
    ok
}

# Regression for quoted table names with spaces after ADD COLUMN.
# If sqlite_schema.sql drops quotes around the table name, reopening the DB can fail to parse schema.
@cross-check-integrity
test alter_table_add_column_with_space_in_name_keeps_quoted_schema_sql {
    CREATE TABLE "t t"("a a" TEXT, "b b" TEXT);
    ALTER TABLE "t t" ADD COLUMN "c c" TEXT;

    SELECT sql LIKE 'CREATE TABLE "t t"%' FROM sqlite_schema WHERE type = 'table' AND name = 't t';
    SELECT instr(sql, 'c c') > 0 FROM sqlite_schema WHERE type = 'table' AND name = 't t';
    PRAGMA integrity_check;
}
expect {
    1
    1
    ok
}
# --- Trigger rewriting for ALTER TABLE RENAME ---

# Verify trigger fires correctly after table rename
@cross-check-integrity
test alter-table-rename-trigger-fires-after-rename {
    CREATE TABLE t1 (a, b);
    CREATE TABLE log (x, y);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        INSERT INTO log VALUES (new.a, new.b);
    END;
    ALTER TABLE t1 RENAME TO t2;
    INSERT INTO t2 VALUES (1, 2);
    SELECT * FROM log;
}
expect {
    1|2
}

# Verify trigger body UPDATE command targets renamed table
@cross-check-integrity
test alter-table-rename-trigger-body-update {
    CREATE TABLE t1 (a, b);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        UPDATE t1 SET b = 99 WHERE a = new.a;
    END;
    ALTER TABLE t1 RENAME TO t2;
    INSERT INTO t2 VALUES (1, 0);
    SELECT * FROM t2;
}
expect {
    1|99
}

# Verify trigger body DELETE command targets renamed table
@cross-check-integrity
test alter-table-rename-trigger-body-delete {
    CREATE TABLE t1 (a INTEGER PRIMARY KEY, b);
    CREATE TABLE t2 (id, x);
    INSERT INTO t2 VALUES (1, 'keep');
    INSERT INTO t2 VALUES (2, 'remove');
    CREATE TRIGGER trig1 AFTER UPDATE ON t1 BEGIN
        DELETE FROM t2 WHERE id = old.a;
    END;
    INSERT INTO t1 VALUES (2, 'hello');
    ALTER TABLE t2 RENAME TO t3;
    UPDATE t1 SET b = 'world' WHERE a = 2;
    SELECT * FROM t3;
}
expect {
    1|keep
}

# Verify trigger body INSERT into a different renamed table
@cross-check-integrity
test alter-table-rename-trigger-body-insert-other-table {
    CREATE TABLE t1 (a, b);
    CREATE TABLE log (a, b);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        INSERT INTO log VALUES (new.a, new.b);
    END;
    ALTER TABLE log RENAME TO log2;
    INSERT INTO t1 VALUES (10, 20);
    SELECT * FROM log2;
}
expect {
    10|20
}

# Verify trigger schema entry tbl_name is updated
@cross-check-integrity
test alter-table-rename-trigger-schema-tbl-name {
    CREATE TABLE t1 (a);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        SELECT 1;
    END;
    ALTER TABLE t1 RENAME TO t2;
    SELECT tbl_name FROM sqlite_schema WHERE type = 'trigger';
}
expect {
    t2
}

# --- Trigger rewriting for ALTER TABLE RENAME COLUMN ---

# Verify trigger fires after column rename (NEW refs updated)
@cross-check-integrity
test alter-table-rename-column-trigger-fires {
    CREATE TABLE t1 (a, b);
    CREATE TABLE log (x, y);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        INSERT INTO log VALUES (new.a, new.b);
    END;
    ALTER TABLE t1 RENAME COLUMN b TO c;
    INSERT INTO t1 VALUES (10, 20);
    SELECT * FROM log;
}
expect {
    10|20
}

# Verify UPDATE OF column list is rewritten
@cross-check-integrity
test alter-table-rename-column-trigger-update-of {
    CREATE TABLE t1 (a, b, c);
    INSERT INTO t1 VALUES (1, 2, 3);
    CREATE TABLE log (x);
    CREATE TRIGGER trig1 AFTER UPDATE OF b ON t1 BEGIN
        INSERT INTO log VALUES (new.b);
    END;
    ALTER TABLE t1 RENAME COLUMN b TO d;
    UPDATE t1 SET d = 42 WHERE a = 1;
    SELECT * FROM log;
}
expect {
    42
}

# Verify trigger body UPDATE SET column names and WHERE refs updated
@cross-check-integrity
test alter-table-rename-column-trigger-body-update-refs {
    CREATE TABLE t1 (a INTEGER PRIMARY KEY, b);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        UPDATE t1 SET b = new.b + 1 WHERE a = new.a;
    END;
    ALTER TABLE t1 RENAME COLUMN b TO c;
    INSERT INTO t1 VALUES (1, 100);
    SELECT a, c FROM t1;
}
expect {
    1|101
}

# Verify WHEN clause column refs are rewritten
@cross-check-integrity
test alter-table-rename-column-trigger-when-clause {
    CREATE TABLE t1 (a, b);
    CREATE TABLE log (x);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 WHEN new.b > 0 BEGIN
        INSERT INTO log VALUES (new.b);
    END;
    ALTER TABLE t1 RENAME COLUMN b TO c;
    INSERT INTO t1 VALUES (1, -5);
    INSERT INTO t1 VALUES (2, 10);
    SELECT * FROM log;
}
expect {
    10
}

# Verify INSERT column list in trigger body is NOT rewritten for different table
@cross-check-integrity
test alter-table-rename-column-trigger-insert-other-table {
    CREATE TABLE t1 (a, b);
    CREATE TABLE log (a, b);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        INSERT INTO log (a, b) VALUES (new.a, new.b);
    END;
    ALTER TABLE t1 RENAME COLUMN b TO c;
    INSERT INTO t1 VALUES (1, 2);
    SELECT * FROM log;
}
expect {
    1|2
}

test alter-table-rename-column-scoping-other-table {
    DROP TABLE IF EXISTS t1;
    DROP TABLE IF EXISTS t2;
    DROP TABLE IF EXISTS log;
    CREATE TABLE t1 (a, b);
    CREATE TABLE t2 (a, b);
    INSERT INTO t2 VALUES (1, 999);
    CREATE TABLE log (v);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        INSERT INTO log SELECT t2.b FROM t2 WHERE t2.a = new.a;
    END;
    ALTER TABLE t1 RENAME COLUMN b TO c;
    INSERT INTO t1 VALUES (1, 0);
    SELECT * FROM log;
}
expect {
    999
}

test alter-table-rename-column-subquery {
    DROP TABLE IF EXISTS t1;
    DROP TABLE IF EXISTS t2;
    CREATE TABLE t1 (a, b);
    CREATE TABLE t2 (x, y);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        INSERT INTO t2 VALUES (new.a, (SELECT b FROM t1 WHERE a = new.a));
    END;
    ALTER TABLE t1 RENAME COLUMN b TO c;
    INSERT INTO t1 VALUES (1, 55);
    SELECT * FROM t2;
}
expect {
    1|55
}

test alter-table-rename-trigger-exists-subquery {
    DROP TABLE IF EXISTS t1;
    DROP TABLE IF EXISTS t2;
    DROP TABLE IF EXISTS log;
    CREATE TABLE t1 (a INTEGER PRIMARY KEY, b);
    CREATE TABLE t2 (x, y);
    CREATE TABLE log (v);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        INSERT INTO log SELECT b FROM t1 WHERE EXISTS (SELECT 1 FROM t2 WHERE t2.x = t1.a);
    END;
    INSERT INTO t2 VALUES (1, 0);
    ALTER TABLE t1 RENAME COLUMN b TO c;
    INSERT INTO t1 VALUES (1, 42);
    SELECT * FROM log;
}
expect {
    42
}

test alter-table-rename-then-rename-column-trigger {
    DROP TABLE IF EXISTS t1;
    DROP TABLE IF EXISTS log;
    CREATE TABLE t1 (a INTEGER PRIMARY KEY, b);
    CREATE TABLE log (v);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        INSERT INTO log VALUES (new.b + 100);
    END;
    ALTER TABLE t1 RENAME COLUMN b TO c;
    INSERT INTO t1 VALUES (1, 77);
    SELECT * FROM log;
}
expect {
    177
}

test alter-table-rename-column-case-expr-trigger {
    DROP TABLE IF EXISTS t1;
    DROP TABLE IF EXISTS log;
    CREATE TABLE t1 (a INTEGER PRIMARY KEY, b);
    CREATE TABLE log (v);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        INSERT INTO log VALUES (CASE WHEN new.b > 10 THEN 'big' ELSE 'small' END);
    END;
    ALTER TABLE t1 RENAME COLUMN b TO c;
    INSERT INTO t1 VALUES (1, 50);
    INSERT INTO t1 VALUES (2, 5);
    SELECT * FROM log ORDER BY rowid;
}
expect {
    big
    small
}

test alter-table-rename-column-union-trigger {
    DROP TABLE IF EXISTS t1;
    DROP TABLE IF EXISTS log;
    CREATE TABLE t1 (a INTEGER PRIMARY KEY, b);
    CREATE TABLE log (v);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        INSERT INTO log SELECT new.b UNION ALL SELECT new.b * 2;
    END;
    ALTER TABLE t1 RENAME COLUMN b TO c;
    INSERT INTO t1 VALUES (1, 10);
    SELECT * FROM log ORDER BY v;
}
expect {
    10
    20
}

test alter-table-rename-column-old-ref-trigger {
    DROP TABLE IF EXISTS t1;
    DROP TABLE IF EXISTS log;
    CREATE TABLE t1 (a INTEGER PRIMARY KEY, b);
    CREATE TABLE log (old_val, new_val);
    CREATE TRIGGER trig1 AFTER UPDATE ON t1 BEGIN
        INSERT INTO log VALUES (old.b, new.b);
    END;
    ALTER TABLE t1 RENAME COLUMN b TO c;
    INSERT INTO t1 VALUES (1, 10);
    UPDATE t1 SET c = 20 WHERE a = 1;
    SELECT * FROM log;
}
expect {
    10|20
}

test alter-table-rename-column-multiple-triggers {
    DROP TABLE IF EXISTS t1;
    DROP TABLE IF EXISTS log1;
    DROP TABLE IF EXISTS log2;
    CREATE TABLE t1 (a INTEGER PRIMARY KEY, b);
    CREATE TABLE log1 (v);
    CREATE TABLE log2 (v);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        INSERT INTO log1 VALUES (new.b);
    END;
    CREATE TRIGGER trig2 AFTER INSERT ON t1 BEGIN
        INSERT INTO log2 VALUES (new.b * 10);
    END;
    ALTER TABLE t1 RENAME COLUMN b TO c;
    INSERT INTO t1 VALUES (1, 7);
    SELECT * FROM log1;
}
expect {
    7
}

test alter-table-rename-column-cross-table-insert {
    DROP TABLE IF EXISTS src;
    DROP TABLE IF EXISTS dst;
    DROP TABLE IF EXISTS log;
    CREATE TABLE src (a INTEGER PRIMARY KEY, b);
    CREATE TABLE dst (x, y);
    CREATE TABLE log (v);
    INSERT INTO src VALUES (1, 500);
    CREATE TRIGGER trig1 AFTER INSERT ON dst BEGIN
        INSERT INTO log SELECT b FROM src WHERE a = new.x;
    END;
    ALTER TABLE src RENAME COLUMN b TO c;
    INSERT INTO dst VALUES (1, 0);
    SELECT * FROM log;
}
expect {
    500
}

# Round-trip rename: renaming away and back must restore the original column
# name in the stored trigger SQL (issue #6625). Previously the in-memory
# trigger.sql was not refreshed after a column rename, so the second rename
# saw the stale (pre-rename) text and made no change.
@cross-check-integrity
test alter-table-rename-column-trigger-round-trip-stored-sql {
    CREATE TABLE log (msg TEXT);
    CREATE TABLE core (id TEXT UNIQUE, row_rank TEXT UNIQUE);
    CREATE TRIGGER core_ai AFTER INSERT ON core BEGIN
        INSERT INTO log VALUES (NEW.id || ':' || NEW.row_rank);
    END;
    ALTER TABLE core RENAME COLUMN row_rank TO row_rank2;
    ALTER TABLE core RENAME COLUMN row_rank2 TO row_rank;
    SELECT sql FROM sqlite_schema WHERE name = 'core_ai';
}
expect pattern {
    CREATE TRIGGER core_ai AFTER INSERT ON core\s+BEGIN\s+INSERT INTO log VALUES\s*\(NEW\.id \|\| ':' \|\| NEW\.row_rank\);?\s+END
}

# Round-trip rename: WHEN clause column references must also be restored.
@cross-check-integrity
test alter-table-rename-column-trigger-round-trip-when-clause {
    CREATE TABLE log (v);
    CREATE TABLE t1 (a, b);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 WHEN NEW.b > 0 BEGIN
        INSERT INTO log VALUES (NEW.b);
    END;
    ALTER TABLE t1 RENAME COLUMN b TO b2;
    ALTER TABLE t1 RENAME COLUMN b2 TO b;
    SELECT sql FROM sqlite_schema WHERE name = 'trig1';
}
expect pattern {
    CREATE TRIGGER trig1 AFTER INSERT ON t1 WHEN NEW\.b > 0\s+BEGIN\s+INSERT INTO log VALUES\s*\(NEW\.b\);?\s+END
}

# Round-trip rename: UPDATE OF column list must also be restored.
@cross-check-integrity
test alter-table-rename-column-trigger-round-trip-update-of {
    CREATE TABLE log (v);
    CREATE TABLE t1 (a, b);
    CREATE TRIGGER trig1 AFTER UPDATE OF b ON t1 BEGIN
        INSERT INTO log VALUES (NEW.b);
    END;
    ALTER TABLE t1 RENAME COLUMN b TO b2;
    ALTER TABLE t1 RENAME COLUMN b2 TO b;
    SELECT sql FROM sqlite_schema WHERE name = 'trig1';
}
expect pattern {
    CREATE TRIGGER trig1 AFTER UPDATE OF b ON t1\s+BEGIN\s+INSERT INTO log VALUES\s*\(NEW\.b\);?\s+END
}

# Round-trip rename: subsequent inserts must fire the trigger correctly.
# Without the fix, the stored trigger SQL persists the intermediate name
# (row_rank2), so reopening the database -- or any code path that recompiles
# the trigger from the stored SQL -- would fail with "no such column: row_rank2".
@cross-check-integrity
test alter-table-rename-column-trigger-round-trip-fires {
    CREATE TABLE log (msg TEXT);
    CREATE TABLE core (id TEXT UNIQUE, row_rank TEXT UNIQUE);
    CREATE TRIGGER core_ai AFTER INSERT ON core BEGIN
        INSERT INTO log VALUES (NEW.id || ':' || NEW.row_rank);
    END;
    INSERT INTO core(id, row_rank) VALUES ('i-001', 'A001');
    ALTER TABLE core RENAME COLUMN row_rank TO row_rank2;
    ALTER TABLE core RENAME COLUMN row_rank2 TO row_rank;
    INSERT INTO core(id, row_rank) VALUES ('i-002', 'A002');
    SELECT msg FROM log ORDER BY rowid;
}
expect {
    i-001:A001
    i-002:A002
}

# Multi-hop rename A -> B -> C -> A: confirms the in-memory trigger.sql
# refresh works for arbitrary chains, not just a single round trip.
@cross-check-integrity
test alter-table-rename-column-trigger-multi-hop-rename {
    CREATE TABLE log (v);
    CREATE TABLE t1 (a, b);
    CREATE TRIGGER trig1 AFTER INSERT ON t1 BEGIN
        INSERT INTO log VALUES (NEW.b);
    END;
    ALTER TABLE t1 RENAME COLUMN b TO b2;
    ALTER TABLE t1 RENAME COLUMN b2 TO b3;
    ALTER TABLE t1 RENAME COLUMN b3 TO b;
    SELECT sql FROM sqlite_schema WHERE name = 'trig1';
}
expect pattern {
    CREATE TRIGGER trig1 AFTER INSERT ON t1\s+BEGIN\s+INSERT INTO log VALUES\s*\(NEW\.b\);?\s+END
}

